# ==========================================
# Smart Home IoT Application - Environment
# ==========================================

# --- Environment ---
# development, staging, production
ENVIRONMENT=development

# --- Core Database Configuration ---
# Options: 'json', 'postgres'
# Use 'json' for local testing (uses data.json)
# Use 'postgres' for production
DATABASE_TYPE=json
DATA_FILE_PATH=data.json

# --- NoSQL Database Configuration ---
# Used for storing telemetry/sensor time-series logs
# Options: 'mongo'
NOSQL_TYPE=mongo
MONGO_URL=mongodb://localhost:27017

# --- MQTT Broker Configuration ---
# For local testing, you can use Mosquitto without auth (port 1883)
# For production/cloud (e.g., HiveMQ), use port 8883 with TLS
MQTT_BROKER=
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=